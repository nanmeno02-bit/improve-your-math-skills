<!DOCTYPE html><html lang="zh-CN"><head>  <meta charset="UTF-8" />  <meta name="viewport" content="width=device-width, initial-scale=1.0" />  <title>饮食记录 | Calorie Tracker</title>  <style>    :root {      color-scheme: light;      --bg: #f4f6fb;      --card: #ffffff;      --text: #1f2a44;      --muted: #6b7280;      --accent: #3b82f6;      --accent-2: #10b981;      --danger: #ef4444;      --shadow: 0 12px 32px rgba(0,0,0,0.08);      --radius: 14px;    }    * { box-sizing: border-box; }    body {      margin: 0; padding: 24px;      font-family: "Inter", "PingFang SC", "Segoe UI", sans-serif;      background: var(--bg); color: var(--text);      display: flex; justify-content: center;    }    .container {      width: min(1080px, 100%);      background: var(--card);      border-radius: var(--radius);      box-shadow: var(--shadow);      padding: 24px 24px 32px;    }    h1 { margin: 0 0 6px; font-size: 26px; }    .subtitle { color: var(--muted); margin-bottom: 18px; }    .grid {      display: grid; gap: 14px;      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));      align-items: end;    }    label { display: block; font-weight: 600; font-size: 14px; color: var(--muted); margin-bottom: 6px; }    input, select {      width: 100%; padding: 10px 12px;      border: 1px solid #e5e7eb; border-radius: 10px;      font-size: 15px; background: #f9fafb;    }    input:focus, select:focus { outline: 2px solid var(--accent); }    button.primary {      padding: 12px 14px; border: none;      border-radius: 10px; background: var(--accent);      color: white; font-size: 16px; cursor: pointer; font-weight: 700;      transition: transform 0.05s ease, box-shadow 0.1s;      box-shadow: 0 8px 20px rgba(59,130,246,0.35);    }    button.primary:hover { transform: translateY(-1px); }    button.primary:active { transform: translateY(0); }    .section { margin-top: 22px; }    .table {      width: 100%; border-collapse: collapse; margin-top: 10px;      background: #fbfcff; border-radius: 12px; overflow: hidden;      box-shadow: 0 4px 16px rgba(0,0,0,0.04);    }    .table th, .table td {      padding: 10px 12px; border-bottom: 1px solid #e5e7eb; text-align: left;      font-size: 14px;    }    .table th { background: #eef2ff; color: #374151; }    .table tr:last-child td { border-bottom: none; }    .badge { display: inline-block; padding: 4px 8px; border-radius: 8px; background: #e0f2fe; color: #0369a1; font-weight: 700; }    .muted { color: var(--muted); }    .danger { color: var(--danger); cursor: pointer; border: none; background: transparent; }    .cards {      display: grid; gap: 12px;      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));      margin: 16px 0;    }    .card {      background: #f8fafc; border-radius: 12px; padding: 14px 16px;      border: 1px solid #e5e7eb;    }    .card .label { color: var(--muted); font-size: 13px; }    .card .value { font-size: 22px; font-weight: 800; margin-top: 6px; }    canvas { background: #fff; border-radius: 12px; padding: 12px; box-shadow: 0 4px 18px rgba(0,0,0,0.05); }    .flex { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }  </style></head><body><div class="container">  <h1>饮食记录</h1>  <div class="subtitle">本地保存（localStorage），支持按日查看，自动热量计算与可视化。</div>  <div class="grid">    <div>      <label for="date">日期</label>      <input type="date" id="date" />    </div>    <div>      <label for="food">食物名称</label>      <input list="food-list" id="food" placeholder="如：鸡胸肉" required />      <datalist id="food-list"></datalist>    </div>    <div>      <label for="grams">数量（g）</label>      <input type="number" id="grams" min="1" placeholder="例如 150" required />    </div>    <div>      <label for="meal">用餐时间</label>      <select id="meal">        <option>早餐</option><option>午餐</option><option>晚餐</option><option>加餐</option>      </select>    </div>    <div>      <label for="price">价格（元）</label>      <input type="number" id="price" min="0" step="0.01" placeholder="例如 12.5" />    </div>    <div>      <label for="calPer100">热量 (kcal/100g)</label>      <input type="number" id="calPer100" min="0" step="0.1" placeholder="自动填充，可手动改" />    </div>    <div style="grid-column: 1 / -1;">      <button class="primary" id="add">添加记录</button>    </div>  </div>  <div class="section">    <div class="flex">      <div>        <label class="muted">查看日期</label><br/>        <input type="date" id="viewDate" />      </div>      <div class="muted">切换日期以查看对应记录与图表。</div>    </div>    <div class="cards">      <div class="card"><div class="label">当天总热量 (kcal)</div><div class="value" id="sumCal">0</div></div>      <div class="card"><div class="label">当天总花费 (元)</div><div class="value" id="sumCost">0</div></div>      <div class="card"><div class="label">记录条数</div><div class="value" id="sumCount">0</div></div>    </div>    <table class="table" id="table">      <thead>        <tr>          <th>食物</th><th>数量(g)</th><th>用餐</th><th>热量(kcal)</th><th>价格(元)</th><th></th>        </tr>      </thead>      <tbody></tbody>    </table>    <div class="section">      <h3>每日热量 & 花费趋势</h3>      <canvas id="trendChart" height="200"></canvas>    </div>    <div class="section">      <h3>当日食物热量占比</h3>      <canvas id="pieChart" height="200"></canvas>    </div>  </div></div><script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script><script>  // ===== 热量表 (kcal/100g) =====  const calorieTable = {    "鸡胸肉": 165, "牛肉": 250, "猪里脊": 242, "鸡蛋": 155, "牛奶": 62,    "燕麦": 379, "米饭": 116, "面条": 138, "土豆": 77, "红薯": 86,    "西蓝花": 34, "胡萝卜": 41, "黄瓜": 16, "番茄": 18, "苹果": 52,    "香蕉": 89, "橙子": 47, "花生": 567, "杏仁": 579, "豆腐": 76,    "虾仁": 99, "三文鱼": 208, "鳕鱼": 82, "玉米": 96, "黑巧克力": 546  };  // ===== DOM =====  const dateInput = document.getElementById("date");  const viewDate = document.getElementById("viewDate");  const foodInput = document.getElementById("food");  const gramsInput = document.getElementById("grams");  const mealInput = document.getElementById("meal");  const priceInput = document.getElementById("price");  const calPer100Input = document.getElementById("calPer100");  const addBtn = document.getElementById("add");  const tableBody = document.querySelector("#table tbody");  const sumCalEl = document.getElementById("sumCal");  const sumCostEl = document.getElementById("sumCost");  const sumCountEl = document.getElementById("sumCount");  const foodList = document.getElementById("food-list");  let trendChart, pieChart;  const STORAGE_KEY = "dietRecordsV3";  // ===== 初始化 =====  function initFoodList() {    foodList.innerHTML = Object.keys(calorieTable)      .map(f => `<option value="${f}">`).join("");  }  function today() {    return new Date().toISOString().slice(0,10);  }  function loadData() {    return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");  }  function saveData(data) {    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));  }  function getRecords(dateStr) {    const data = loadData();    return data[dateStr] || [];  }  function setRecords(dateStr, records) {    const data = loadData();    data[dateStr] = records;    saveData(data);  }  // ===== 渲染表格与摘要 =====  function renderTable(dateStr) {    const records = getRecords(dateStr);    tableBody.innerHTML = "";    let sumCal = 0, sumCost = 0;    records.forEach((r, idx) => {      sumCal += r.calories;      sumCost += r.price || 0;      const tr = document.createElement("tr");      tr.innerHTML = `        <td>${r.food}</td>        <td>${r.grams}</td>        <td><span class="badge">${r.meal}</span></td>        <td>${r.calories.toFixed(1)}</td>        <td>${(r.price||0).toFixed(2)}</td>        <td><button class="danger" data-idx="${idx}">删除</button></td>      `;      tableBody.appendChild(tr);    });    sumCalEl.textContent = sumCal.toFixed(1);    sumCostEl.textContent = sumCost.toFixed(2);    sumCountEl.textContent = records.length;    // 删除处理    tableBody.queryeel("bodan).foa(tn   .nc ( onst Number(da.i   conlgest);  lspe, );  etat) rl;  } ; ==  == fctn dendDt() con da=