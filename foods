<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>饮食记录</title>
  <style>
    :root {
      color-scheme: light dark;
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #1f2933;
      --accent: #3b82f6;
      --muted: #6b7280;
      --danger: #ef4444;
      --shadow: 0 8px 24px rgba(0,0,0,0.08);
    }
    body {
      margin: 0; padding: 24px;
      font-family: "Inter", "PingFang SC", "Segoe UI", sans-serif;
      background: var(--bg); color: var(--text);
      display: flex; justify-content: center;
    }
    .container {
      width: min(720px, 100%);
      background: var(--card); border-radius: 14px;
      box-shadow: var(--shadow); padding: 24px;
    }
    h1 { margin: 0 0 12px; font-size: 24px; }
    .subtitle { color: var(--muted); margin-bottom: 20px; }
    form { display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
    label { font-weight: 600; font-size: 14px; color: var(--muted); }
    input, select {
      width: 100%; padding: 10px 12px;
      border: 1px solid #e5e7eb; border-radius: 10px;
      font-size: 15px; background: #f9fafb;
    }
    input:focus, select:focus { outline: 2px solid var(--accent); }
    button {
      grid-column: 1 / -1;
      padding: 12px 16px; border: none; border-radius: 10px;
      background: var(--accent); color: white; font-size: 16px;
      cursor: pointer; font-weight: 700; letter-spacing: 0.3px;
      transition: transform 0.05s ease, box-shadow 0.1s;
      box-shadow: 0 6px 18px rgba(59,130,246,0.35);
    }
    button:hover { transform: translateY(-1px); }
    button:active { transform: translateY(0); }
    .list { margin-top: 24px; display: grid; gap: 12px; }
    .item {
      border: 1px solid #e5e7eb; border-radius: 12px;
      padding: 14px 16px; background: #fdfefe;
      display: grid; grid-template-columns: 1fr auto; gap: 8px;
      align-items: center;
    }
    .item .meta { color: var(--muted); font-size: 13px; }
    .item .name { font-weight: 700; }
    .delete {
      border: none; background: transparent; color: var(--danger);
      cursor: pointer; font-weight: 700; padding: 6px 8px;
    }
    .empty { text-align: center; color: var(--muted); padding: 24px 0; }
  </style>
</head>
<body>
  <div class="container">
    <h1>饮食记录</h1>
    <div class="subtitle">记录今天吃了什么，数据保存在本地浏览器（localStorage）。</div>

    <form id="form">
      <div>
        <label for="food">食物名称</label>
        <input id="food" type="text" placeholder="如：鸡胸肉 / 苹果" required />
      </div>
      <div>
        <label for="amount">数量</label>
        <input id="amount" type="text" placeholder="如：200g / 1个" required />
      </div>
      <div>
        <label for="meal">用餐时间</label>
        <select id="meal">
          <option value="早餐">早餐</option>
          <option value="午餐">午餐</option>
          <option value="晚餐">晚餐</option>
          <option value="加餐">加餐</option>
        </select>
      </div>
      <button type="submit">添加记录</button>
    </form>

    <div class="list" id="list"></div>
    <div class="empty" id="empty">今天还没有记录，先添加一条吧！</div>
  </div>

  <script>
    const STORAGE_KEY = "dietRecords";
    const form = document.getElementById("form");
    const listEl = document.getElementById("list");
    const emptyEl = document.getElementById("empty");

    function todayKey() {
      const d = new Date();
      // 只按日期归档，格式 YYYY-MM-DD
      return d.toISOString().slice(0,10);
    }

    function loadRecords() {
      const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
      return data[todayKey()] || [];
    }

    function saveRecords(records) {
      const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
      data[todayKey()] = records;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    }

    function render() {
      const records = loadRecords();
      listEl.innerHTML = "";
      if (!records.length) {
        emptyEl.style.display = "block";
        return;
      }
      emptyEl.style.display = "none";
      records.forEach((rec, idx) => {
        const div = document.createElement("div");
        div.className = "item";
        div.innerHTML = `
          <div>
            <div class="name">${rec.food}</div>
            <div class="meta">${rec.meal} · ${rec.amount}</div>
          </div>
          <button class="delete" data-index="${idx}">删除</button>
        `;
        listEl.appendChild(div);
      });
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const food = document.getElementById("food").value.trim();
      const amount = document.getElementById("amount").value.trim();
      const meal = document.getElementById("meal").value;
      if (!food || !amount) return;

      const records = loadRecords();
      records.push({ food, amount, meal, ts: Date.now() });
      saveRecords(records);
      form.reset();
      render();
    });

    listEl.addEventListener("click", (e) => {
      if (e.target.classList.contains("delete")) {
        const idx = Number(e.target.dataset.index);
        const records = loadRecords();
        records.splice(idx, 1);
        saveRecords(records);
        render();
      }
    });

    render();
  </script>
</body>
</html>
